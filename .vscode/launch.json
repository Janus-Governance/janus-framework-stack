{
  "version": "0.2.0",
  "configurations": [
    
    {
      "name": "Run Janus VSCode Connector",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/dev/janus-vscode-connector",
        "${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dev/janus-vscode-connector/dist/**/*.js"
      ]
    }
  ]
}
